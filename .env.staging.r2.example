APP_NAME=Cut SaaS
ENVIRONMENT=staging
DEBUG=False

DATABASE_URL=postgresql://cut_user:change-me@db-host:5432/cut_saas

BASE_DATA_DIR=./data
STORAGE_BACKEND=r2
STORAGE_BUCKET=replace-me-bucket
STORAGE_PUBLIC_BASE_URL=
STORAGE_ENDPOINT_URL=https://replace-me-account-id.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=replace-me
STORAGE_SECRET_ACCESS_KEY=replace-me

ARTIFACT_RETENTION_DAYS=30
PRESERVE_APPROVED_ARTIFACTS=True

SECRET_KEY=replace-with-a-unique-secret-with-at-least-32-characters
SESSION_COOKIE_NAME=cut_saas_session
SESSION_MAX_AGE_SECONDS=1209600
SESSION_COOKIE_SECURE=True
ALLOWED_HOSTS=staging.example.com
PROXY_TRUSTED_HOSTS=127.0.0.1

NODE_BIN=node
NODE_EXTRA_PATH=

YTDLP_VERBOSE=True
YTDLP_COOKIES_FILE=
YTDLP_COOKIES_BROWSER=
YTDLP_COOKIES_BROWSER_PROFILE=

TRANSCRIPTION_PROVIDER=auto
WHISPER_MODEL=base
WHISPER_PRECISION=auto

LLM_RERANK_ENABLED=False
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_TOP_N=12
LLM_TIMEOUT_SECONDS=20
OLLAMA_BASE_URL=http://127.0.0.1:11434
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1

MAX_CONCURRENT_PIPELINE_JOBS=1
PIPELINE_QUEUE_BACKEND=worker
PIPELINE_LOCK_STALE_SECONDS=3600

SHORT_MIN_DURATION_SECONDS=20
SHORT_MAX_DURATION_SECONDS=180
LONG_MIN_DURATION_SECONDS=300
LONG_MAX_DURATION_SECONDS=900

BILLING_PROVIDER=stripe
